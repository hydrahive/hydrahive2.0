#!/usr/bin/env bash
# HydraHive2 — pre-commit-Guard für SPEC.md.
#
# Regel: SPEC.md wird NUR in standalone-Commits geändert (kein Mix mit Code
# in derselben Commit). Begründung in Issue #34.
#
# Bypass für Notfälle: BYPASS_SPEC_GUARD=1 git commit ...

set -euo pipefail

if [ "${BYPASS_SPEC_GUARD:-0}" = "1" ]; then
  echo "[pre-commit] SPEC-Guard via BYPASS_SPEC_GUARD=1 umgangen — bewusste Entscheidung."
  exit 0
fi

# Liste der staged Files
staged="$(git diff --cached --name-only)"

# Prüfen ob SPEC.md staged ist
spec_staged="$(printf '%s\n' "$staged" | grep -E '^SPEC\.md$' || true)"
if [ -z "$spec_staged" ]; then
  exit 0
fi

# Andere Files daneben?
others="$(printf '%s\n' "$staged" | grep -vE '^SPEC\.md$' || true)"
if [ -z "$others" ]; then
  # Nur SPEC.md → standalone, OK
  exit 0
fi

cat >&2 <<EOF

╔══════════════════════════════════════════════════════════════════╗
║  SPEC-Guard: Mixed-Commit blockiert                              ║
╠══════════════════════════════════════════════════════════════════╣
║  SPEC.md darf NUR in standalone-Commits geändert werden          ║
║  — siehe Issue #34, SPEC-Workflow.                              ║
║                                                                   ║
║  Code-Files daneben:                                              ║
EOF
printf '%s\n' "$others" | head -10 | sed 's/^/║    · /' >&2
[ "$(printf '%s\n' "$others" | wc -l)" -gt 10 ] && echo "║    · …" >&2
cat >&2 <<EOF
║                                                                   ║
║  Lösung:                                                          ║
║    1. SPEC-Änderung unstaged: git restore --staged SPEC.md       ║
║    2. Code committen wie geplant                                  ║
║    3. SPEC.md separat committen (mit explizit dokumentierter      ║
║       Freigabe vom User)                                          ║
║                                                                   ║
║  Notfall-Bypass: BYPASS_SPEC_GUARD=1 git commit ...               ║
╚══════════════════════════════════════════════════════════════════╝

EOF
exit 1
