# HydraHive2 Backend Environment Variables — Template.
# Kopiere zu /etc/hydrahive2/env (chmod 600), oder als Override für install.sh.

# Pfade
HH_DATA_DIR=/var/lib/hydrahive2
HH_CONFIG_DIR=/etc/hydrahive2

# Bind-Adresse — auf Mehrnutzer-Server idealerweise 127.0.0.1 + nginx davor
HH_HOST=127.0.0.1
HH_PORT=8001

# JWT-Secret — wird vom Installer auto-generiert in /etc/hydrahive2/secret_key.
# Manuell setzen nur falls du Sessions zwischen Servern teilen willst.
# HH_SECRET_KEY=...

# Token-Lifetime (Standard 24h)
HH_JWT_EXPIRE_MINUTES=1440

# Erstes Admin-Passwort (sonst random generiert + ins Log).
# NACH erstem Login NICHT mehr nötig.
# HH_INITIAL_ADMIN_PASSWORD=...

# CORS (Komma-Liste). Default: localhost:5173/5174 für Dev.
# Auf Production-Server: nur die echte Domain.
# HH_CORS_ORIGINS=https://hydrahive.example.com

# PostgreSQL Datamining-Mirror (optional).
# Wird vom Installer automatisch befüllt. Leer lassen = Mirror deaktiviert.
# HH_PG_MIRROR_DSN=postgresql://hydrahive_mirror:pass@127.0.0.1:5432/hydrahive_mirror

# AgentLink — externer Service.
# HH_AGENTLINK_URL=http://127.0.0.1:7700
